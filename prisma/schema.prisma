// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH.JS MODELS
// ============================================

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role      @default(USER)
  welcomeEmailSent Boolean   @default(false)
  disabled         Boolean   @default(false)
  tosAcceptedAt    DateTime? // Terms of Service acceptance timestamp

  // Email Preferences (GDPR compliant)
  unsubscribeToken    String  @unique @default(cuid()) // Token for one-click unsubscribe
  emailMarketingOptIn Boolean @default(true) // Marketing/promotional emails
  emailProductUpdates Boolean @default(true) // Product updates and announcements
  emailSecurityAlerts Boolean @default(true) // Security alerts (recommended always on)

  // Two-Factor Authentication
  twoFactorSecret      String? // Encrypted TOTP secret
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String[] // Hashed backup codes (bcrypt)

  // Onboarding
  onboardingCompleted   Boolean   @default(false) // User finished or dismissed onboarding
  onboardingDismissedAt DateTime? // When user dismissed the onboarding

  accounts               Account[]
  sessions               Session[]
  trustedDevices         TrustedDevice[]
  userSessions           UserSession[]
  loginHistory           LoginHistory[]
  subscription           Subscription?
  dataExportRequests     DataExportRequest[]
  accountDeletionRequest AccountDeletionRequest?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([disabled])
  @@index([twoFactorEnabled])
  @@index([unsubscribeToken])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@index([expires])
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String // Hashed device token (stored in browser cookie)
  deviceName String // Browser/device info for user reference
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime // When the trust expires (e.g., 30 days from creation)
  createdAt  DateTime @default(now())

  @@unique([userId, tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@index([tokenHash])
}

// ============================================
// SESSION MANAGEMENT MODELS
// ============================================

model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String    @unique // Links to Auth.js Session.sessionToken
  ipAddress    String?
  userAgent    String?
  deviceName   String? // Parsed from userAgent (e.g., "Chrome on macOS")
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime? // Null = active, set = revoked

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([sessionToken])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([lastActiveAt])
  @@index([userId, revokedAt, expiresAt, lastActiveAt]) // Optimized for active sessions query with ordering
}

model LoginHistory {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress  String?
  userAgent  String?
  deviceName String? // Parsed from userAgent
  success    Boolean
  failReason String? // "invalid_credentials", "account_disabled", "2fa_failed"
  provider   String // "credentials", "google", "github", "two-factor"

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([userId, success])
  @@index([userId, success, createdAt]) // Optimized for metrics query: count by user, success, and date range
}

// ============================================
// SUBSCRIPTION MODELS
// ============================================

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId       String?            @unique
  stripeSubscriptionId   String?            @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  stripeTrialEnd         DateTime? // Trial period end date
  status                 SubscriptionStatus @default(INACTIVE)
  statusChangedAt        DateTime? // When status last changed (for grace period tracking)
  plan                   Plan               @default(FREE)
  cancelAtPeriodEnd      Boolean            @default(false)
  dunningEmails          DunningEmail[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@index([plan])
  @@index([userId, status])
  @@index([plan, status])
  @@index([deletedAt])
}

// ============================================
// USAGE METERING MODELS
// ============================================

model Usage {
  id            String @id @default(cuid())
  userId        String
  period        String // Billing period in YYYY-MM format (e.g., "2024-01")
  apiCalls      Int    @default(0)
  projectsCount Int    @default(0)
  storageBytes  BigInt @default(0)
  teamMembers   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, period])
  @@index([userId])
  @@index([period])
  @@index([userId, period])
}

// ============================================
// ENUMS
// ============================================

enum Role {
  USER
  ADMIN
}

enum Plan {
  FREE
  PLUS
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

// ============================================
// ADMIN CONFIGURATION MODELS
// ============================================

model PlanConfig {
  id             String   @id @default(cuid())
  plan           Plan     @unique
  name           String
  description    String?
  monthlyPriceId String? // Stripe Price ID for monthly billing
  yearlyPriceId  String? // Stripe Price ID for yearly billing
  monthlyPrice   Int      @default(0) // Display price in cents
  yearlyPrice    Int      @default(0) // Display price in cents
  features       String[] // Feature list for display
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model AppConfig {
  id          String  @id @default(cuid())
  key         String  @unique
  value       Json
  description String?
  category    String // "general", "features", "billing", "email"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([key])
}

model ConfigAuditLog {
  id         String @id @default(cuid())
  entityType String // "PlanConfig", "AppConfig", "User"
  entityId   String
  action     String // "CREATE", "UPDATE", "DELETE"
  changes    Json // { field: { old: value, new: value } }
  userId     String // Admin who made the change
  userEmail  String // For display purposes

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================
// GDPR COMPLIANCE MODELS
// ============================================

model DataExportRequest {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      DataExportStatus @default(PENDING)
  downloadUrl String? // Temporary signed URL for download
  expiresAt   DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model AccountDeletionRequest {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason       String?
  scheduledFor DateTime // When the account will be permanently deleted
  canceledAt   DateTime?

  createdAt DateTime @default(now())

  @@index([scheduledFor])
}

enum DataExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

// ============================================
// DUNNING FLOW MODELS
// ============================================

model DunningEmail {
  id             String           @id @default(cuid())
  subscriptionId String
  subscription   Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  emailType      DunningEmailType
  sentAt         DateTime         @default(now())
  recipientEmail String
  emailStatus    EmailSendStatus  @default(PENDING)
  errorMessage   String?

  createdAt DateTime @default(now())

  @@unique([subscriptionId, emailType])
  @@index([subscriptionId])
  @@index([subscriptionId, emailType])
  @@index([sentAt])
}

enum DunningEmailType {
  DAY_0_PAYMENT_FAILED
  DAY_3_REMINDER
  DAY_7_FINAL_WARNING
  DAY_10_SUSPENDED
  PAYMENT_RECOVERED
}

enum EmailSendStatus {
  PENDING
  SENT
  FAILED
}

// ============================================
// WEBHOOK IDEMPOTENCY MODEL
// ============================================

model WebhookEvent {
  id            String    @id @default(cuid())
  stripeEventId String    @unique
  eventType     String
  processed     Boolean   @default(false)
  processedAt   DateTime?
  apiVersion    String?
  errorMessage  String?

  createdAt DateTime @default(now())

  @@index([stripeEventId])
  @@index([eventType])
  @@index([processedAt])
}

// ============================================
// PROMOTION CODE MODELS
// ============================================

model PromotionCode {
  id                String       @id @default(cuid())
  code              String       @unique // Human-readable code (e.g., "SUMMER2024")
  stripePromotionId String       @unique // Stripe promotion code ID
  stripeCouponId    String // Stripe coupon ID
  description       String?
  discountType      DiscountType // PERCENTAGE or FIXED
  discountValue     Int // Percentage (e.g., 20 for 20%) or amount in cents
  currency          String? // Required for FIXED discounts
  active            Boolean      @default(true)

  // Usage restrictions
  maxRedemptions Int @default(0) // 0 = unlimited
  timesRedeemed  Int @default(0)
  expiresAt      DateTime?

  // Metadata
  createdBy String // Admin user ID
  notes     String? // Internal notes for admin

  // Relations
  usages PromotionUsage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active])
  @@index([expiresAt])
  @@index([createdBy])
}

model PromotionUsage {
  id               String        @id @default(cuid())
  promotionCodeId  String
  promotionCode    PromotionCode @relation(fields: [promotionCodeId], references: [id], onDelete: Cascade)
  userId           String
  subscriptionId   String?
  stripeCheckoutId String        @unique
  discountAmount   Int // Amount discounted in cents

  createdAt DateTime @default(now())

  @@index([promotionCodeId])
  @@index([userId])
  @@index([subscriptionId])
  @@index([createdAt])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}
